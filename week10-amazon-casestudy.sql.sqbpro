-- Q1: Revenue per order (after discount)
SELECT
  o.order_id,
  c.name          AS customer,
  p.name          AS product,
  p.price,
  o.quantity,
  o.discount,
  ROUND(p.price * o.quantity * (1 - o.discount), 2)
                  AS revenue
FROM orders_amz o
JOIN customers c ON o.cust_id = c.cust_id
JOIN products  p ON o.prod_id = p.prod_id
ORDER BY revenue DESC;

-- Q2: Customer-wise total spend + tier
SELECT
  c.name,
  c.city,
  c.tier,
  COUNT(o.order_id)                               AS orders,
  ROUND(SUM(p.price * o.quantity * (1-o.discount)),2)
                                                  AS total_spend,
  ROUND(AVG(p.price * o.quantity * (1-o.discount)),2)
                                                  AS avg_order
FROM customers c
LEFT JOIN orders_amz o ON c.cust_id = o.cust_id
LEFT JOIN products   p ON o.prod_id  = p.prod_id
GROUP BY c.cust_id, c.name, c.city, c.tier
ORDER BY total_spend DESC;

-- Q3: Category-wise revenue + % of total
WITH cat_rev AS (
  SELECT
    p.category,
    ROUND(SUM(p.price * o.quantity * (1-o.discount)),2) AS cat_total
  FROM orders_amz o
  JOIN products p ON o.prod_id = p.prod_id
  GROUP BY p.category
),
grand AS (
  SELECT SUM(cat_total) AS grand_total FROM cat_rev
)
SELECT
  c.category,
  c.cat_total,
  ROUND(c.cat_total * 100.0 / g.grand_total, 1) AS pct_of_total
FROM cat_rev c, grand g
ORDER BY cat_total DESC;

-- Q4: Monthly revenue trend
SELECT
  SUBSTR(order_dt, 1, 7)  AS month,
  COUNT(*)                AS orders,
  ROUND(SUM(p.price * o.quantity * (1-o.discount)),2)
                          AS revenue
FROM orders_amz o
JOIN products p ON o.prod_id = p.prod_id
GROUP BY SUBSTR(order_dt, 1, 7)
ORDER BY month;

-- Q5: Customer ranking by spend (Window Function!)
WITH cust_spend AS (
  SELECT
    c.name, c.tier,
    ROUND(SUM(p.price * o.quantity * (1-o.discount)),2)
      AS total_spend
  FROM customers c
  JOIN orders_amz o ON c.cust_id = o.cust_id
  JOIN products   p ON o.prod_id  = p.prod_id
  GROUP BY c.cust_id, c.name, c.tier
)
SELECT
  name, tier, total_spend,
  RANK()       OVER (ORDER BY total_spend DESC) AS overall_rank,
  RANK()       OVER (PARTITION BY tier
                     ORDER BY total_spend DESC) AS tier_rank
FROM cust_spend
ORDER BY overall_rank;

-- Q6: Repeat customers (2+ orders)
SELECT
  c.name, c.city, c.tier,
  COUNT(o.order_id) AS order_count
FROM customers c
JOIN orders_amz o ON c.cust_id = o.cust_id
GROUP BY c.cust_id, c.name, c.city, c.tier
HAVING COUNT(o.order_id) &gt;= 2
ORDER BY order_count DESC;

-- Q7: Best product per category (Window Function)
WITH prod_rev AS (
  SELECT
    p.category,
    p.name AS product,
    ROUND(SUM(p.price * o.quantity * (1-o.discount)),2)
      AS revenue,
    RANK() OVER (
      PARTITION BY p.category
      ORDER BY SUM(p.price * o.quantity * (1-o.discount)) DESC
    ) AS cat_rank
  FROM products p
  JOIN orders_amz o ON p.prod_id = o.prod_id
  GROUP BY p.prod_id, p.category, p.name
)
SELECT category, product, revenue
FROM prod_rev
WHERE cat_rank = 1
ORDER BY revenue DESC;</sql><current_tab id="0"/></tab_sql></sqlb_project>
